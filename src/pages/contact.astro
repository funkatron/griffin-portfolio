---
import PageLayout from '../layouts/PageLayout.astro';

const email = 'hello@griffin.studio';
const socials = [
	{ label: 'Instagram', href: 'https://instagram.com/griffin' },
	{ label: 'ArtStation', href: 'https://artstation.com/griffin' },
];
---

<PageLayout title="Contact" description="Contact Griffin">
	<header class="contact-header">
		<h1 class="display-title">Contact</h1>
		<p class="meta-label">Collaborations &amp; inquiries</p>
	</header>

	<p class="contact-copy">
		For commissions, features, or community shout-outs, reach out directly.
	</p>

	<p class="contact-email">
		<a href={`mailto:${email}`}>{email}</a>
	</p>

	<ul class="contact-socials">
		{
			socials.map((social) => (
				<li>
					<a href={social.href} rel="noopener noreferrer" target="_blank">
						{social.label}
					</a>
				</li>
			))
		}
	</ul>
</PageLayout>

<style>
	.contact-header {
		margin-bottom: var(--space-lg);
	}

	.contact-copy {
		max-width: 42ch;
		font-size: 1.0625rem;
	}

	.contact-email {
		margin: var(--space-md) 0;
		font-family: var(--font-display);
		font-size: clamp(1.5rem, 4vw, 2.5rem);
		font-weight: 700;
		text-transform: uppercase;
	}

	.contact-email a {
		text-decoration: none;
	}

	.contact-socials {
		list-style: none;
		margin: var(--space-lg) 0 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}

	.contact-socials a {
		font-size: var(--text-label);
		letter-spacing: 0.2em;
		text-transform: uppercase;
		text-decoration: none;
	}
</style>
