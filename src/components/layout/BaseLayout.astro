---
import '../../styles/global.css';
import DisappearingNav from './DisappearingNav.astro';
import Footer from './Footer.astro';

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	hideNav?: boolean;
	fullBleed?: boolean;
}

const {
	title = 'Griffin',
	description = '3D rendered artworks — editorial portfolio',
	ogImage = '/placeholders/og-home.svg',
	hideNav = false,
	fullBleed = false,
} = Astro.props;

const pageTitle = title === 'Griffin' ? title : `${title} — Griffin`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'http://localhost:4321');
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:type" content="website" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=Noto+Sans+JP:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
		<title>{pageTitle}</title>
	</head>
	<body>
		{!hideNav && <DisappearingNav />}
		<main class:list={{ 'page-shell': !fullBleed, 'fade-in': true }}>
			<slot />
		</main>
		{!fullBleed && <Footer />}
	</body>
</html>
