---
interface Props {
	title: string;
	year: number;
	series: string;
	tools?: string[];
	description?: string;
}

const { title, year, series, tools = [], description } = Astro.props;
const seriesLabel = series === 'astronaut-dreams' ? 'Astronaut Dreams' : 'Other';
---

<div class="credits-overlay">
	<p class="meta-label">{year} — {seriesLabel}</p>
	<h2 class="credits-overlay__title">{title}</h2>
	{description && <p class="credits-overlay__copy">{description}</p>}
	{tools.length > 0 && <p class="credits-overlay__tools meta-label">{tools.join(' / ')}</p>}
</div>

<style>
	.credits-overlay__title {
		margin: 0.35rem 0 0.5rem;
		font-family: var(--font-display);
		font-size: clamp(1.5rem, 4vw, 2.5rem);
		font-weight: 700;
		text-transform: uppercase;
		line-height: 0.95;
	}

	.credits-overlay__copy {
		margin: 0 0 0.5rem;
		max-width: 40ch;
		font-size: 0.95rem;
		line-height: 1.45;
	}

	.credits-overlay__tools {
		margin: 0;
		color: var(--dragon-aqua);
	}
</style>
