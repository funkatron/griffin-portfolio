---
interface Props {
	lines: string[];
	meta?: string;
}

const { lines, meta } = Astro.props;
---

<div class="title-plate">
	<div class="title-plate__lines">
		{lines.map((line) => <h1 class="display-title">{line}</h1>)}
	</div>
	{meta && <p class="title-plate__meta meta-label">{meta}</p>}
</div>

<style>
	.title-plate {
		padding: var(--space-xl) 0 var(--space-lg);
		border-bottom: 1px solid var(--color-rule);
	}

	.title-plate__lines {
		display: flex;
		flex-direction: column;
		gap: 0.1em;
	}

	.title-plate__meta {
		margin: var(--space-md) 0 0;
	}
</style>
